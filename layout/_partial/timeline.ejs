<div class="flex gap-8">
  <div class="flex-1 min-w-0">
  <%
    // 文章按月份分组
    let postsByMonth = {};
    site.posts.sort('-date').forEach(post => {
      let month = post.date.format('YYYY年M月');
      if (!postsByMonth[month]) postsByMonth[month] = [];
      postsByMonth[month].push(post);
    });
    let months = Object.keys(postsByMonth).sort((a, b) => b.localeCompare(a));
  %>

  <header class="gradient-header mb-8 fade-up">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-flex h-2 w-2 rounded-full bg-indigo-500 animate-pulse"></span>
      <span class="text-sm font-medium text-slate-500 dark:text-slate-400">时间线</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">归档</h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
      共 <span class="font-semibold text-indigo-600 dark:text-indigo-400"><%= site.posts.length %></span> 篇文章，跨越 <span class="font-semibold text-indigo-600 dark:text-indigo-400"><%= months.length %></span> 个月份
    </p>
  </header>

  <% if (months.length === 0) { %>
    <div class="text-center py-20 text-slate-400 dark:text-slate-600">
      <svg class="w-16 h-16 mx-auto mb-4 opacity-40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      <p>暂无文章</p>
    </div>
  <% } else { %>

    <% months.forEach((month, index) => { %>
      <section class="month-section mb-6 fade-up" data-index="<%= index %>" style="animation-delay: <%= index * 50 %>ms; <%= index >= 3 ? 'display:none;' : '' %>">
        <!-- 月份标题 -->
        <h2 class="flex items-center gap-3 text-lg font-semibold text-slate-900 dark:text-white mb-4">
          <span><%= month %></span>
          <span class="text-xs font-normal text-slate-400 dark:text-slate-600 px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800">
            <%= postsByMonth[month].length %> 篇
          </span>
        </h2>

        <!-- 文章列表 -->
        <div class="space-y-2 border-l-2 border-slate-200 dark:border-slate-800 pl-5 mb-2">
          <% postsByMonth[month].forEach(post => { %>
            <a href="<%= url_for(post.path) %>" class="timeline-item group flex items-center gap-3 py-2.5 px-3 -ml-3 rounded-lg hover:bg-white dark:hover:bg-slate-900/50 transition-colors relative" style="animation-delay: <%= (index * 50) + (postsByMonth[month].indexOf(post) * 30) %>ms;">
              <!-- 时间线圆点 -->
              <span class="absolute -left-[27px] top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-700 group-hover:bg-indigo-500 group-hover:scale-110 transition-all"></span>
              <time class="text-xs text-slate-400 dark:text-slate-600 font-mono tabular-nums shrink-0">
                <%= post.date.format('MM/DD') %>
              </time>
              <span class="text-sm text-slate-700 dark:text-slate-300 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors truncate">
                <%= post.title %>
              </span>
            </a>
          <% }) %>
        </div>
      </section>
    <% }) %>

    <% if (months.length > 3) { %>
      <div id="load-more-wrapper" class="text-center mt-8 py-4">
        <button id="load-more-btn" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:opacity-90 transition-opacity">
          <span>手动加载更多</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </button>
        <p id="loading-msg" class="mt-4 text-sm text-slate-400 dark:text-slate-600 hidden">
          <svg class="animate-spin inline w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          加载中...
        </p>
        <p id="no-more-msg" class="mt-4 text-sm text-slate-400 dark:text-slate-600 hidden">没有更多了</p>
      </div>
    <% } %>

  <% } %>
  </div>

  <%- partial('_partial/sidebar') %>
  </div>

<script>
(function(){
  const totalMonths = <%= months.length %>;
  if (totalMonths <= 3) return;

  const loadMoreBtn = document.getElementById('load-more-btn');
  const noMoreMsg = document.getElementById('no-more-msg');
  const loadingMsg = document.getElementById('loading-msg');
  if (!loadMoreBtn) return;

  const loader = createLoadMore({
    total: totalMonths,
    loadCount: 3,
    startIndex: 3,
    trigger: loadMoreBtn,
    rootMargin: 600,
    immediate: true,
    onLoad: (i) => {
      const section = document.querySelector('.month-section[data-index="' + i + '"]');
      if (section) section.style.display = 'block';
    },
    onFinish: () => {
      loadMoreBtn.classList.add('hidden');
      if (loadingMsg) loadingMsg.classList.add('hidden');
      if (noMoreMsg) noMoreMsg.classList.remove('hidden');
    }
  });

  loadMoreBtn.addEventListener('click', () => loader.loadMore());
  loader.start();
})();
</script>
