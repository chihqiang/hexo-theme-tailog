<aside class="hidden xl:block w-64 shrink-0">
  <div class="sticky top-20 space-y-6">

    <!-- 最新文章 -->
    <section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
      <h3 class="flex items-center gap-2 text-sm font-semibold text-slate-900 dark:text-white mb-3">
        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        最新文章
      </h3>
      <ul class="space-y-2.5">
        <% site.posts.sort('-date').limit(6).forEach(function(post){ %>
          <li>
            <a href="<%= url_for(post.path) %>" class="group flex items-start gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              <span class="mt-1 w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-700 group-hover:bg-indigo-500 transition-colors shrink-0"></span>
              <span class="line-clamp-2 leading-snug"><%= post.title %></span>
            </a>
          </li>
        <% }) %>
      </ul>
    </section>

    <!-- 分类目录 -->
    <% if (site.categories && site.categories.length > 0) { %>
    <section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
      <h3 class="flex items-center gap-2 text-sm font-semibold text-slate-900 dark:text-white mb-3">
        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        分类
      </h3>
      <ul class="space-y-1.5">
        <% site.categories.sort('-length').limit(8).forEach(function(cat){ %>
          <li>
            <a href="<%= url_for(cat.path) %>" class="group flex items-center justify-between text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
              <span class="truncate"><%= cat.name %></span>
              <span class="text-xs text-slate-400 dark:text-slate-600 tabular-nums shrink-0 ml-2"><%= cat.length %></span>
            </a>
          </li>
        <% }) %>
      </ul>
    </section>
    <% } %>

    <!-- 热门标签 -->
    <% if (site.tags && site.tags.length > 0) { %>
    <section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4">
      <h3 class="flex items-center gap-2 text-sm font-semibold text-slate-900 dark:text-white mb-3">
        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z" />
        </svg>
        标签
      </h3>
      <div class="flex flex-wrap gap-1.5">
        <% site.tags.sort('-length').limit(16).forEach(function(tag){ %>
          <a href="<%= url_for(tag.path) %>" class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            <%= tag.name %>
          </a>
        <% }) %>
      </div>
    </section>
    <% } %>

  </div>
</aside>
