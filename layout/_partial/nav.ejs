<nav id="navbar" class="sticky top-0 z-40 border-b border-slate-200/60 dark:border-slate-800/60 bg-white/95 dark:bg-slate-900/95 backdrop-blur-xl shadow-sm transition-all duration-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex h-16 items-center justify-between gap-4">
      <!-- 左侧：Logo + 桌面导航 -->
      <div class="flex items-center gap-6 min-w-0">
        <!-- 网站标题 -->
        <a href="/" class="flex items-center gap-2 group shrink-0">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-600 dark:bg-indigo-500 text-white font-bold text-sm shadow-sm group-hover:shadow-md transition-shadow">
            <%= (conf('title') || 'B').charAt(0) %>
          </span>
          <span class="hidden sm:inline text-lg font-semibold text-slate-900 dark:text-white tracking-tight">
            <%= conf('title') %>
          </span>
        </a>

        <!-- 桌面端菜单 -->
        <div id="desktop-menu" class="hidden lg:flex items-center gap-0.5">
          <% let menu = conf('menu') || {} %>
          <% let menuItems = Object.entries(menu) %>
          <% menuItems.forEach(([name, path], index) => { %>
            <a href="<%- url_for(path) %>" class="nav-item px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors" data-index="<%= index %>">
              <%= name %>
            </a>
          <% }) %>

          <!-- 更多下拉菜单（自适应溢出项） -->
          <div id="dropdown-menu" class="relative group hidden">
            <button class="px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors flex items-center gap-1">
              更多
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div id="dropdown-content" class="absolute left-0 mt-2 w-44 bg-white dark:bg-slate-900 rounded-lg shadow-lg ring-1 ring-slate-900/5 dark:ring-slate-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 transform translate-y-1 group-hover:translate-y-0 py-1">
            </div>
          </div>
        </div>
      </div>

      <!-- 右侧按钮组 -->
      <div class="flex items-center gap-1.5 shrink-0">
        <!-- 搜索按钮 + 快捷键 -->
        <button
          id="searchButton"
          class="flex items-center gap-2 pl-2.5 pr-1.5 py-1.5 rounded-lg text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors border border-slate-200 dark:border-slate-800"
          aria-label="搜索"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline text-xs text-slate-400 dark:text-slate-600">搜索</span>
          <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-mono bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-600 border border-slate-200 dark:border-slate-700">⌘K</kbd>
        </button>

        <div class="w-px h-5 bg-slate-200 dark:bg-slate-800"></div>

        <!-- 深色模式切换 -->
        <button id="theme-toggle" class="p-2 rounded-lg text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors" aria-label="切换主题">
          <svg id="sun-icon" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg id="moon-icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <!-- 移动端汉堡按钮 -->
        <button id="mobile-menu-button" aria-label="切换菜单" class="lg:hidden p-2 rounded-lg text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-slate-200/60 dark:border-slate-800/60 bg-white dark:bg-slate-950">
    <div class="px-4 py-3 space-y-0.5">
      <% menu = conf('menu') || {} %>
      <% for (let name in menu) { if(menu.hasOwnProperty(name)) { %>
        <a href="<%- url_for(menu[name]) %>" class="block py-2.5 px-3 rounded-md text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors">
          <%= name %>
        </a>
      <% } } %>
    </div>
  </div>
</nav>

<%- partial('search', { posts: page.posts || site.posts }) %>
