<%
  // 首页 Hero 统计数据
  let totalPosts = site.posts.length;
  let totalTags = site.tags.length;
  let totalCats = site.categories.length;
%>
<% if (page.current === 1 && is_home()) { %>
  <!-- 首页 Hero 区域 -->
  <section class="mb-10 sm:mb-12 fade-up">
    <div class="flex items-center gap-2 mb-3">
      <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="text-sm font-medium text-slate-500 dark:text-slate-400">
        <%= conf('subtitle') || conf('description') %>
      </span>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white tracking-tight">
      最新文章
    </h1>

    <!-- 统计数据 -->
    <div class="mt-5 flex flex-wrap gap-4 sm:gap-6">
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 tabular-nums"><%= totalPosts %></span>
        <span class="text-sm text-slate-400 dark:text-slate-500">篇文章</span>
      </div>
      <div class="w-px h-7 bg-slate-200 dark:bg-slate-800"></div>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 tabular-nums"><%= totalTags %></span>
        <span class="text-sm text-slate-400 dark:text-slate-500">个标签</span>
      </div>
      <div class="w-px h-7 bg-slate-200 dark:bg-slate-800"></div>
      <div class="flex items-center gap-2">
        <span class="text-2xl font-bold text-indigo-600 dark:text-indigo-400 tabular-nums"><%= totalCats %></span>
        <span class="text-sm text-slate-400 dark:text-slate-500">个分类</span>
      </div>
    </div>
  </section>
  <% } %>

  <!-- 双栏布局：文章列表 + 侧边栏 -->
  <div class="flex gap-8">
    <!-- 文章列表 -->
    <div class="flex-1 min-w-0">
      <div class="space-y-4">
        <% page.posts.each(function(post) { %>
        <%
          let postWordCount = strip_html(post.content).length;
          let postReadTime = Math.max(1, Math.ceil(postWordCount / 400));
        %>
        <article class="article-card group relative rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-indigo-200 dark:hover:border-indigo-700 transition-all duration-300 p-5 sm:p-6 fade-up" style="animation-delay: <%= (page.current - 1) * 10 %>ms;">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <!-- 分类标签 + 日期 -->
              <div class="flex items-center gap-3 mb-1.5 text-sm">
                <% if (post.categories && post.categories.length) { %>
                  <% post.categories.forEach(function(cat){ %>
                    <a href="<%= url_for(cat.path) %>" class="relative z-10 text-indigo-600 dark:text-indigo-400 font-medium hover:underline">
                      <%= cat.name %>
                    </a>
                  <% }) %>
                <% } else { %>
                  <span class="text-slate-400 dark:text-slate-600">未分类</span>
                <% } %>
                <span class="text-slate-300 dark:text-slate-700">·</span>
                <time class="text-slate-400 dark:text-slate-500"><%- date(post.date, "YYYY-MM-DD") %></time>
                <span class="text-slate-300 dark:text-slate-700">·</span>
                <span class="text-slate-400 dark:text-slate-500"><%= postReadTime %> 分钟</span>
              </div>

              <!-- 标题 -->
              <h3 class="text-lg sm:text-xl font-semibold text-slate-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                <a href="<%- url_for(post.path) %>"><%- post.title %></a>
              </h3>

              <!-- 摘要 -->
              <p class="mt-1.5 text-sm text-slate-500 dark:text-slate-400 line-clamp-2 post-content">
                <%- strip_html(post.content).substr(0, 140) %>...
              </p>

              <!-- 标签 -->
              <% if (post.tags && post.tags.length) { %>
              <div class="mt-3 flex flex-wrap gap-2">
                <% post.tags.forEach(function(tag){ %>
                  <a href="<%= url_for(tag.path) %>" class="relative z-10 inline-flex items-center px-2 py-0.5 rounded text-xs bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                    <%= tag.name %>
                  </a>
                <% }) %>
              </div>
              <% } %>
            </div>

            <!-- 箭头 -->
            <div class="hidden sm:flex items-center self-center text-slate-300 dark:text-slate-700 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 group-hover:translate-x-0.5 transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>

          <!-- 整卡片可点击 -->
          <a href="<%- url_for(post.path) %>" class="absolute inset-0" aria-label="<%= post.title %>"></a>
        </article>
        <% }) %>
      </div>
    </div>

    <!-- 侧边栏 -->
    <%- partial('_partial/sidebar') %>
  </div>
