<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
  <%- partial('_partial/head') %>

<body class="bg-slate-100 dark:bg-slate-950 text-slate-700 dark:text-slate-300 min-h-screen flex flex-col antialiased transition-colors duration-200">

  <%- partial('_partial/nav') %>

  <!-- 阅读进度条 -->
  <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-indigo-600 dark:bg-indigo-400 z-50 transition-all duration-150 ease-out" style="width: 0%"></div>

  <!-- 主内容区 -->
  <main class="flex-1 w-full">
    <%- typeof body !== 'undefined' ? body : '' %>
  </main>

  <%- partial('_partial/footer') %>

  <!-- 回到顶部按钮 -->
  <button id="back-to-top" class="fixed bottom-6 right-6 p-2.5 rounded-full bg-slate-800 dark:bg-slate-200 text-white dark:text-slate-900 shadow-lg ring-1 ring-slate-900/5 hover:scale-110 active:scale-95 transition-all duration-200 opacity-0 invisible z-50" aria-label="回到顶部">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>
</body>
</html>
