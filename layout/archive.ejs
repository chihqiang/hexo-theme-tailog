<div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
  <% if (is_archive()) { %>
    <%- partial('_partial/timeline') %>
  <% } else if (page.path && page.path.startsWith('categories/')) { %>
    <%- partial('_partial/post_card') %>
  <% } else if (page.path && page.path.startsWith('tags/')) { %>
    <%- partial('_partial/post_card') %>
  <% } else { %>
    <%- partial('_partial/post_list') %>
  <% } %>
</div>
<% if (!is_archive()) { %> <%- partial('_partial/paginator') %> <% } %>
